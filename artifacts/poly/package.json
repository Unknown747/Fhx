{
  "name": "polyhft-autotrading-v3",
  "version": "3.0.0",
  "description": "Production TypeScript autotrading bot for Polymarket binary markets — Polygon mainnet, 7-strategy stack.",
  "main": "dist/index.js",
  "scripts": {
    "build":     "rimraf dist && tsc",
    "start":     "node dist/index.js",
    "paper":     "DRY_RUN=true node dist/index.js",
    "live":      "DRY_RUN=false node dist/index.js",
    "markets":   "node dist/examples/liveMarkets.js",
    "test:full": "node dist/test/fullTest.js",
    "typecheck": "tsc --noEmit",
    "clean":     "rimraf dist"
  },
  "files": [
    "dist",
    "config",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "polymarket",
    "prediction-market",
    "crypto",
    "up-down",
    "binary-options",
    "trading",
    "solana",
    "bitcoin"
  ],
  "author": "PolyHFT-Autotrading-V3 Contributors",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "dotenv": "^16.5.1",
    "ethers": "^6.16.0",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.3.4",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.5"
  }
}
